# Copy this file to .env and fill in your values
# Skopiuj ten plik jako .env i uzupełnij swoje dane

# MT5 account credentials (optional — can be entered via browser login form)
# Dane konta MT5 (opcjonalnie — można podać przez formularz logowania)
MT5_LOGIN=your_mt5_login_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server_name

# API key used for internal session auth (set any random string)
# Klucz API do autoryzacji sesji (ustaw dowolny losowy ciąg znaków)
API_KEY=change_me_to_a_random_string

# Polling interval in seconds (default 1.0)
# Interwał odczytu danych w sekundach (domyślnie 1.0)
POLL_INTERVAL=1.0

# Automatically initialise the MT5 terminal when the server starts (default False).
# Set to True only if you use MT5 and want it to connect at startup.
# Automatycznie inicjalizuj terminal MT5 przy starcie serwera (domyślnie False).
# Ustaw True tylko jeśli używasz MT5 i chcesz żeby połączył się przy starcie.
AUTO_INIT_MT5=False

# Allowed CORS origins (JSON array)
# Dozwolone źródła CORS (tablica JSON)
CORS_ORIGINS=["http://localhost:8000"]
